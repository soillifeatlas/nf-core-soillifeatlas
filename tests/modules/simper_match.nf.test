nextflow_process {
    name "Test SIMPER_MATCH"
    script "modules/local/simper_match.nf"
    process "SIMPER_MATCH"
    profile "local"

    test("runs on tiny MGF fixtures and produces a matches parquet") {
        when {
            params {
                simper_min_cos = 0.5
                simper_min_matched_peaks = 2
            }
            process {
                """
                input[0] = [
                    [id: 'test_soil'],
                    file("${projectDir}/tests/fixtures/tiny/tiny_soil.mgf")
                ]
                input[1] = file("${projectDir}/tests/fixtures/tiny/tiny_atlas.mgf")
                input[2] = file("${projectDir}/tests/fixtures/tiny/tiny_simper_atlas_mgf.parquet")
                """
            }
        }
        then {
            assert process.success
            assert path(process.out.matches[0][1]).exists()
            assert path(process.out.versions[0]).exists()
        }
    }
}
