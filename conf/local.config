/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for the `local` profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    v0.1: run processes on the host Python env (soillifeatlas editable-installed).
    Containers arrive in Phase 7 once the Docker image is published.
----------------------------------------------------------------------------------------
*/

process {
    executor = 'local'
    // No container: rely on the host `soillifeatlas` package + `bin/` scripts
    // on PATH (nf-core stages bin/ automatically for each task).

    // Local dev machines (and CI runners) only have a few GB of RAM; the
    // nf-core resource labels in base.config assume HPC-class nodes. Clamp
    // everything way down here so `process_medium`/`process_high` don't
    // get rejected as exceeding-available-memory on a laptop.
    cpus   = 1
    memory = { 2.GB * task.attempt }
    time   = { 1.h  * task.attempt }

    withLabel:process_single      { cpus = 1; memory = { 1.GB * task.attempt } }
    withLabel:process_low         { cpus = 1; memory = { 1.GB * task.attempt } }
    withLabel:process_medium      { cpus = 1; memory = { 2.GB * task.attempt } }
    withLabel:process_high        { cpus = 2; memory = { 4.GB * task.attempt } }
    withLabel:process_high_memory { memory = { 4.GB * task.attempt } }
}

docker.enabled      = false
apptainer.enabled   = false
singularity.enabled = false
podman.enabled      = false
conda.enabled       = false
